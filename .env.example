# PostgreSQL local (docker-compose ou instalação nativa)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boletim?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/boletim?schema=public"

# Supabase + Vercel (produção)
# 1. Crie um projeto NOVO em https://supabase.com/dashboard
# 2. Settings → Database → Reset database password (anote a senha)
# 3. Connect → copie Session pooler (6543) e Direct (5432)
#
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[SENHA]@db.[PROJECT_REF].supabase.co:5432/postgres"
#
# 4. Restaure o backup: .\scripts\restore-to-supabase.ps1 -DirectUrl "..." -PoolerUrl "..."
# 5. Configure a Vercel: .\scripts\setup-vercel-env.ps1 -DatabaseUrl "..." -DirectUrl "..."
